diff --git a/tokens_ingest/scripts/test/trader-bot-delivery-smoke.ts b/tokens_ingest/scripts/test/trader-bot-delivery-smoke.ts
new file mode 100644
index 0000000..5095c30
--- /dev/null
+++ b/tokens_ingest/scripts/test/trader-bot-delivery-smoke.ts
@@ -0,0 +1,135 @@
+import { randomUUID } from "node:crypto";
+import { readFile } from "node:fs/promises";
+import dotenv from "dotenv";
+import { closeDb, createDb } from "../../src/db/client";
+import { runs } from "../../src/db/schema";
+import { PreparationOutputSchema, type PreparationOutput } from "../../src/contracts/preparation";
+import {
+  createConfiguredSignalDeliverySender,
+  drainSignalDeliveryOutbox,
+  enqueueSignalDelivery,
+} from "../../src/delivery/outbox";
+import { loadConfig } from "../../src/config";
+import { initQueue, shutdownQueue } from "../../src/jobs/queue";
+
+dotenv.config();
+
+async function main(): Promise<void> {
+  const options = parseArgs(process.argv.slice(2));
+  const config = loadConfig();
+  const db = createDb(config.DATABASE_URL);
+  await initQueue();
+
+  try {
+    const raw = JSON.parse(await readFile(options.payloadFile, "utf8")) as unknown;
+    const preparation = maybeFreshen(PreparationOutputSchema.parse(raw), options.freshIds);
+    const runId = preparation.run.run_id;
+
+    await db
+      .insert(runs)
+      .values({
+        id: runId,
+        token_address: preparation.payload.prepared_data.token_section.token_address,
+        chain: "solana",
+        status: "ok",
+        trigger_type: preparation.payload.prepared_data.trigger_section.type,
+        triggered_at: new Date(preparation.run.triggered_at),
+      })
+      .onConflictDoNothing();
+
+    const deliveries = await enqueueSignalDelivery(db, preparation, ["trader_bot"]);
+    for (const delivery of deliveries) {
+      if (delivery.outboxId) {
+        await drainSignalDeliveryOutbox(delivery.outboxId);
+      }
+    }
+
+    if (options.duplicateSend && deliveries[0]) {
+      await createConfiguredSignalDeliverySender().send(
+        "trader_bot",
+        {
+          preparation,
+          idempotencyKey: deliveries[0].idempotencyKey,
+        },
+        deliveries[0].idempotencyKey,
+      );
+    }
+
+    process.stdout.write(
+      `${JSON.stringify(
+        {
+          run_id: runId,
+          prepared_snapshot_id: preparation.artifacts.prepared_snapshot_id ?? null,
+          token_address: preparation.payload.prepared_data.token_section.token_address,
+          deliveries,
+          duplicate_send: options.duplicateSend,
+        },
+        null,
+        2,
+      )}\n`,
+    );
+  } finally {
+    await shutdownQueue();
+    await closeDb();
+  }
+}
+
+function maybeFreshen(preparation: PreparationOutput, freshIds: boolean): PreparationOutput {
+  if (!freshIds) return preparation;
+  const runId = randomUUID();
+  const preparedSnapshotId = `stage5-${runId}`;
+  const now = new Date().toISOString();
+  return {
+    ...preparation,
+    run: {
+      ...preparation.run,
+      run_id: runId,
+      triggered_at: now,
+    },
+    artifacts: {
+      ...preparation.artifacts,
+      prepared_snapshot_id: preparedSnapshotId,
+    },
+  };
+}
+
+function parseArgs(args: string[]): {
+  payloadFile: string;
+  freshIds: boolean;
+  duplicateSend: boolean;
+} {
+  let payloadFile = "";
+  let freshIds = false;
+  let duplicateSend = false;
+  for (let index = 0; index < args.length; index += 1) {
+    const arg = args[index];
+    if (arg === "--") {
+      continue;
+    }
+    if (arg === "--payload-file") {
+      payloadFile = args[index + 1] ?? "";
+      index += 1;
+      continue;
+    }
+    if (arg === "--fresh-ids") {
+      freshIds = true;
+      continue;
+    }
+    if (arg === "--duplicate-send") {
+      duplicateSend = true;
+      continue;
+    }
+    throw new Error(`unknown argument: ${arg}`);
+  }
+  if (!payloadFile) {
+    throw new Error("usage: trader-bot-delivery-smoke --payload-file <preparation.json> [--fresh-ids]");
+  }
+  return { payloadFile, freshIds, duplicateSend };
+}
+
+main().catch(async (error: unknown) => {
+  console.error(error);
+  await shutdownQueue().catch(() => undefined);
+  await closeDb().catch(() => undefined);
+  process.exit(1);
+});
