{
  "name": "trader",
  "version": "0.1.0",
  "description": "Signal-driven Solana trading bot",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "mainnet:wallet": "tsx src/solana/mainnet-wallet.ts",
    "canary:buy": "tsx src/solana/canary-buy.ts",
    "canary:sell": "tsx src/solana/canary-sell.ts",
    "live:settings": "tsx src/ops/live-settings.ts",
    "ops:positions": "tsx src/ops/positions.ts",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "flow:dry-run": "tsx src/flow/dry-run-flow-signal.ts",
    "flow:live-readiness": "tsx src/flow/live-readiness-report.ts",
    "db:ready": "prisma migrate deploy && prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "@jup-ag/api": "^6.0.48",
    "@prisma/adapter-better-sqlite3": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@solana/kit": "^6.8.0",
    "@solana/spl-token": "0.2.0-alpha.2",
    "bs58": "^5.0.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.0.0",
    "pino": "^10.0.0",
    "prom-client": "^15.1.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "better-sqlite3": "^12.0.0",
    "cross-env": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
