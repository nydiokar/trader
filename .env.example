# ── Wallet ────────────────────────────────────────────────────────────────────
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WALLET_PRIVATE_KEY_BASE58=        # 88-char base58 private key — NEVER commit the real value

# ── RPC ───────────────────────────────────────────────────────────────────────
HELIUS_RPC_URL=                   # https://mainnet.helius-rpc.com/?api-key=...
HELIUS_API_KEY=                   # optional; used when HELIUS_RPC_URL is bare https://mainnet.helius-rpc.com/
HELIUS_RPC_URL_FALLBACK=          # optional, reads only

# ── Jupiter ───────────────────────────────────────────────────────────────────
JUPITER_BASE_URL=https://api.jup.ag/swap/v1/
JUPITER_API_KEY=                  # required when using https://api.jup.ag/* endpoints
RUN_LIVE_JUPITER_TESTS=false      # optional, enables tests/jupiter.live.test.ts
JUPITER_LIVE_TEST_MINTS=          # optional override; default set is USDC,BONK,JUP,JTO,RAY

# ── Jito ──────────────────────────────────────────────────────────────────────
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
JITO_TIP_LAMPORTS=100000          # 0.0001 SOL

# ── Submission ────────────────────────────────────────────────────────────────
SUBMISSION_MODE=rpc               # rpc | helius_sender | jito
SUBMISSION_FALLBACK_RPC=true      # fallback to normal RPC on pre-acceptance Sender/Jito sync errors
HELIUS_SENDER_URL=https://sender.helius-rpc.com/fast
HELIUS_SENDER_TIP_LAMPORTS=200000 # 0.0002 SOL minimum for default Helius Sender dual routing

# ── Webhook ───────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=                   # min 32 bytes — generate with: openssl rand -hex 32
WEBHOOK_PORT=8080
FLOW_DRY_RUN_WEBHOOK_SECRET=      # min 32 bytes; must match Flow TRADER_BOT_WEBHOOK_SECRET
FLOW_DRY_RUN_PRODUCTION_TRIAL=false
FLOW_EXECUTION_JOURNAL_DIR=data/execution-journals
TOKENS_INGEST_BASE_URL=http://127.0.0.1:3001
TOKENS_INGEST_SERVICE_SECRET=      # min 32 bytes; must match tokens_ingest POSITION_SERVICE_SECRET
FLOW_EXIT_POLL_ENABLED=false             # keep false for buy-only live mode
FLOW_EXIT_POLL_INTERVAL_MS=30000

# ── Risk ──────────────────────────────────────────────────────────────────────
DAILY_SOL_CAP=0.1                        # static fallback; /signal reads runtime live settings per request
PER_SIGNAL_SOL_CAP=0.0001
PER_TOKEN_COOLDOWN_MINUTES=30
WALLET_SOL_FLOOR=0.15
DEFAULT_SLIPPAGE_BPS=300

# ── Tripwires ─────────────────────────────────────────────────────────────────
RUGCHECK_API_KEY=                 # optional
TRIPWIRES_AS_BLOCKERS=false

# ── Observability ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=               # optional — required for M7 notifications
TELEGRAM_CHAT_ID=                 # optional
LOG_LEVEL=info

# ── Modes ─────────────────────────────────────────────────────────────────────
DRY_RUN=false                     # true = full pipeline except network submission
KILL_SWITCH=false

# Live mainnet spending is not test-driven. Use `pnpm canary:buy -- --live ...`
# for explicit one-shot acceptance trades.

# ── Priority fee ──────────────────────────────────────────────────────────────
PRIORITY_FEE_LEVEL=High           # Medium | High | VeryHigh

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=file:./data/bot.db   # local default — adjust path for other environments
