generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Spec §2.4 — idempotency state machine
model Signal {
  signalId    String   @id @map("signal_id")
  receivedAt  Int      @map("received_at")
  rawPayload  String   @map("raw_payload")
  state       String   // received | in_flight | done | failed | rejected
  decision    String?
  resultJson  String?  @map("result_json")
  completedAt Int?     @map("completed_at")

  trade Trade?

  @@map("signals")
}

// Spec §2.5 — nonce replay protection
model Nonce {
  nonce  String @id
  seenAt Int    @map("seen_at")

  @@index([seenAt], name: "idx_nonces_seen_at")
  @@map("nonces")
}

// Spec §3 — trade execution results
model Trade {
  id              Int     @id @default(autoincrement())
  signalId        String  @unique @map("signal_id")
  tokenMint       String  @map("token_mint")
  amountSolIn     Float   @map("amount_sol_in")
  amountOutActual Float?  @map("amount_out_actual")
  signature       String?
  state           String  // confirmed | failed_onchain | expired | uncertain | pre_submit_failed
  submittedVia    String? @map("submitted_via") // jito | rpc
  dryRun          Boolean @default(false) @map("dry_run")
  slippageActual  Float?  @map("slippage_actual")
  createdAt       Int     @map("created_at")
  confirmedAt     Int?    @map("confirmed_at")
  errorMsg        String? @map("error_msg")

  signal Signal @relation(fields: [signalId], references: [signalId])

  @@map("trades")
}

// Flow dry-run pre-execution journal. DB is the durable idempotency record;
// JSON files are rebuilt operator artifacts.
model ExecutionJournal {
  journalId                  String    @id @map("journal_id")
  flowSignalId               String?   @unique @map("flow_signal_id")
  flowRunId                  String?   @map("flow_run_id")
  preparedSnapshotId         String?   @unique @map("prepared_snapshot_id")
  idempotencyKey             String    @unique @map("idempotency_key")
  tokenMint                  String?   @map("token_mint")
  sourceLane                 String?   @map("source_lane")
  signalReason               String?   @map("signal_reason")
  rawPayloadJson             String    @map("raw_payload_json")
  normalizedSignalJson       String?   @map("normalized_signal_json")
  priceLiquiditySnapshotJson String?   @map("price_liquidity_snapshot_json")
  riskConfigJson             String?   @map("risk_config_json")
  riskChecksJson             String?   @map("risk_checks_json")
  riskDecision               String?   @map("risk_decision")
  rejectReason               String?   @map("reject_reason")
  dryRunOrderJson            String?   @map("dry_run_order_json")
  liveExecutionEnabled       Boolean   @default(false) @map("live_execution_enabled")
  livePromotedAt             DateTime? @map("live_promoted_at")
  tradeId                    Int?      @map("trade_id")
  state                      String
  outcome                    String
  errorReason                String?   @map("error_reason")
  errorMessage               String?   @map("error_message")
  journalPath                String?   @map("journal_path")
  leaseOwner                 String?   @map("lease_owner")
  leaseClaimedAt             DateTime? @map("lease_claimed_at")
  leaseExpiresAt             DateTime? @map("lease_expires_at")
  createdAt                  DateTime  @default(now()) @map("created_at")
  updatedAt                  DateTime  @updatedAt @map("updated_at")
  completedAt                DateTime? @map("completed_at")

  @@index([tokenMint], name: "idx_execution_journal_token_mint")
  @@index([state], name: "idx_execution_journal_state")
  @@map("execution_journal")
}

// Durable per-delivery intake attempts for Stage 5 production dry-run evidence.
// ExecutionJournal is the idempotent terminal record; this table keeps every
// observed HTTP decision, including duplicates and invalid payloads.
model FlowDryRunAttempt {
  id                   String   @id @default(uuid())
  status               String
  flowSignalId         String?  @map("flow_signal_id")
  preparedSnapshotId   String?  @map("prepared_snapshot_id")
  idempotencyKey       String?  @map("idempotency_key")
  journalId            String?  @map("journal_id")
  riskDecision         String?  @map("risk_decision")
  rejectReason         String?  @map("reject_reason")
  errorReason          String?  @map("error_reason")
  errorMessage         String?  @map("error_message")
  httpStatusCode       Int?     @map("http_status_code")
  liveExecutionEnabled Boolean  @default(false) @map("live_execution_enabled")
  responseJson         String?  @map("response_json")
  createdAt            DateTime @default(now()) @map("created_at")

  @@index([status], name: "idx_flow_dry_run_attempt_status")
  @@index([flowSignalId], name: "idx_flow_dry_run_attempt_signal")
  @@index([preparedSnapshotId], name: "idx_flow_dry_run_attempt_prepared")
  @@index([idempotencyKey], name: "idx_flow_dry_run_attempt_idempotency")
  @@map("flow_dry_run_attempt")
}

// Spec §4.1 — per-token blocklist
model Blocklist {
  tokenMint String @id @map("token_mint")
  addedAt   Int    @map("added_at")
  reason    String?

  @@map("blocklist")
}

// Spec §4.1 — kill switch + runtime wallet state
model WalletState {
  id         Int     @id @default(1)
  killSwitch Boolean @default(false) @map("kill_switch")
  updatedAt  Int     @map("updated_at")

  @@map("wallet_state")
}
